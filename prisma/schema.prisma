generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum OrgRole {
  OWNER
  ADMIN
  COACH
  MEMBER
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  ARMS
  LEGS
  GLUTES
  CORE
  FULL_BODY
  CARDIO
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  FLEXIBILITY
  BALANCE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id // UUID from Supabase Auth (auth.users.id)
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutLogs      WorkoutLog[]
  foodEntries      FoodEntry[]
  bodyRecords      BodyRecord[]
  memberships      OrganizationMember[]
  coachRelations   CoachStudent[]    @relation("CoachRelations")
  studentRelations CoachStudent[]    @relation("StudentRelations")
  coachSlots       AppointmentSlot[] @relation("CoachSlots")
  coachAppointments Appointment[]   @relation("CoachAppointments")
  studentAppointments Appointment[] @relation("StudentAppointments")
}

// ─── Organization (Tenant) ───────────────────────────────────────────────────

model Organization {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  plan               String   @default("FREE") // FREE | PRO | ENTERPRISE
  inviteCode         String   @unique // 8 碼大寫英數，MEMBER 以此加入
  bookingCutoffHours Int      @default(2)
  approvalTimeoutHours Int    @default(24)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members           OrganizationMember[]
  coachStudents     CoachStudent[]
  appointmentSlots  AppointmentSlot[]
  appointments      Appointment[]
  exercises         Exercise[]
}

model OrganizationMember {
  id       String   @id @default(cuid())
  role     OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model CoachStudent {
  id         String   @id @default(cuid())
  status     String   @default("ACTIVE") // ACTIVE | PAUSED | ENDED
  assignedAt DateTime @default(now())

  coachId   String
  coach     User         @relation("CoachRelations", fields: [coachId], references: [id])
  studentId String
  student   User         @relation("StudentRelations", fields: [studentId], references: [id])
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])

  @@unique([coachId, studentId, orgId])
}

// ─── Exercise Library ────────────────────────────────────────────────────────

model Exercise {
  id          String           @id @default(cuid())
  name        String
  description String?
  muscleGroup MuscleGroup
  category    ExerciseCategory
  isCustom    Boolean          @default(false)
  createdById String?
  orgId       String? // null = 平台全域（內建或個人自訂）；有值 = 館自訂
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  org          Organization?        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  logExercises WorkoutLogExercise[]

  @@index([orgId])
}


// ─── Workout Log ─────────────────────────────────────────────────────────────

model WorkoutLog {
  id        String   @id @default(cuid())
  date      DateTime
  notes     String?
  duration  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutLogExercise[]
}

model WorkoutLogExercise {
  id    String @id @default(cuid())
  order Int    @default(0)

  logId      String
  log        WorkoutLog   @relation(fields: [logId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise     @relation(fields: [exerciseId], references: [id])
  sets       WorkoutSet[]
}

model WorkoutSet {
  id        String  @id @default(cuid())
  setNumber Int
  reps      Int?
  weight    Float?
  duration  Int?
  completed Boolean @default(false)

  exerciseId String
  exercise   WorkoutLogExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// ─── Food / Nutrition ────────────────────────────────────────────────────────

model FoodEntry {
  id        String   @id @default(cuid())
  date      DateTime
  mealType  MealType
  name      String
  calories  Float
  protein   Float?
  carbs     Float?
  fat       Float?
  amount    Float?
  unit      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Appointment ─────────────────────────────────────────────────────────────

model AppointmentSlot {
  id        String   @id @default(cuid())
  startTime DateTime @db.Timestamptz(3)
  endTime   DateTime @db.Timestamptz(3)
  status    String   @default("OPEN") // OPEN | BOOKED | CANCELLED
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  coachId String
  coach   User         @relation("CoachSlots", fields: [coachId], references: [id])
  orgId   String
  org     Organization @relation(fields: [orgId], references: [id])

  appointment Appointment?
}

model Appointment {
  id             String    @id @default(cuid())
  status         String    @default("CONFIRMED") // PENDING | CONFIRMED | REJECTED | EXPIRED | CANCELLED（DB default 保持 CONFIRMED，App 端一律明確指定）
  notes          String?
  expiresAt      DateTime? @db.Timestamptz(3) // PENDING 的過期死線，建立時凍結 = min(now+approvalTimeoutHours, startTime-bookingCutoffHours)
  rejectedReason String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  cancelledAt    DateTime? @db.Timestamptz(3)

  slotId    String          @unique
  slot      AppointmentSlot @relation(fields: [slotId], references: [id])
  studentId String
  student   User            @relation("StudentAppointments", fields: [studentId], references: [id])
  coachId   String
  coach     User            @relation("CoachAppointments", fields: [coachId], references: [id])
  orgId     String
  org       Organization    @relation(fields: [orgId], references: [id])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tableName String
  recordId  String
  operation String   // INSERT | UPDATE | DELETE
  oldData   Json?
  newData   Json?
  actorId   String?
  createdAt DateTime @default(now())
}

// ─── Body Record ─────────────────────────────────────────────────────────────

model BodyRecord {
  id         String   @id @default(cuid())
  date       DateTime
  weight     Float?
  bodyFat    Float?
  muscleMass Float?
  notes      String?
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
